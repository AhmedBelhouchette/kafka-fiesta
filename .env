# LOCAL DEV ONLY — gitignored. Working throwaway credentials so the stack runs.
# Mirror of .env.example with concrete local values.

# ---- InfluxDB ----
DOCKER_INFLUXDB_INIT_USERNAME=admin
DOCKER_INFLUXDB_INIT_PASSWORD=password123
DOCKER_INFLUXDB_INIT_ORG=mon-usine
DOCKER_INFLUXDB_INIT_BUCKET=donnees-usine
DOCKER_INFLUXDB_INIT_ADMIN_TOKEN=my-super-secret-token

# ---- Grafana ----
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin123

# ---- App config ----
KAFKA_BOOTSTRAP=kafka:29092
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_TOKEN=my-super-secret-token
INFLUXDB_ORG=mon-usine
INFLUXDB_BUCKET=donnees-usine

# ---- Data lake ----
DATA_LAKE_ROOT=/data-lake

# ---- Demo timing (accelerated lifecycle so the pipeline is watchable) ----
# Set realistic values for production, e.g. PAUSE_TIMEOUT_SECONDS=600, DEMO_TASK_MINUTES=30,45,60,90,120
BATCH_INTERVAL=5
PAUSE_TIMEOUT_SECONDS=40
IDLE_SHUTDOWN_SECONDS=300
DEMO_TASK_MINUTES=1,2
SENSOR_INTERVAL=5
PRODUCTION_INTERVAL=15
CAPTEURS_ERROR_RATE=0.04
