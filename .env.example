# =============================================================================
# Environment configuration for the Factory Orchestration stack.
#
#   cp .env.example .env   then   docker compose up --build
#
# The values below are LOCAL-DEV-ONLY throwaway credentials so the demo runs
# out of the box. Change every secret before deploying anywhere real.
# .env is gitignored; .env.example (this file) is committed.
# =============================================================================

# ---- InfluxDB (initial setup + auth) ----
DOCKER_INFLUXDB_INIT_USERNAME=admin
DOCKER_INFLUXDB_INIT_PASSWORD=change-me-influx-password
DOCKER_INFLUXDB_INIT_ORG=mon-usine
DOCKER_INFLUXDB_INIT_BUCKET=donnees-usine
DOCKER_INFLUXDB_INIT_ADMIN_TOKEN=change-me-influx-token

# ---- Grafana admin ----
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change-me-grafana-password

# ---- App config consumed by the Python services ----
# Inside docker compose use the service hostnames (kafka / influxdb).
# To run a service directly on the host instead, override to localhost:
#   KAFKA_BOOTSTRAP=localhost:9092
#   INFLUXDB_URL=http://localhost:8086
KAFKA_BOOTSTRAP=kafka:29092
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_TOKEN=change-me-influx-token
INFLUXDB_ORG=mon-usine
INFLUXDB_BUCKET=donnees-usine

# ---- Data lake (Parquet archival root, mounted volume) ----
DATA_LAKE_ROOT=/data-lake

# ---- Demo timing ----
# The factory floor runs on accelerated time so the full machine/task lifecycle
# (assign -> process -> complete, pause -> recover) is visible within a short
# session. For realistic production timings use e.g.:
#   BATCH_INTERVAL=30  PAUSE_TIMEOUT_SECONDS=600  IDLE_SHUTDOWN_SECONDS=1800
#   DEMO_TASK_MINUTES=30,45,60,90,120  PRODUCTION_INTERVAL=30
BATCH_INTERVAL=5
PAUSE_TIMEOUT_SECONDS=40
IDLE_SHUTDOWN_SECONDS=300
DEMO_TASK_MINUTES=1,2
SENSOR_INTERVAL=5
PRODUCTION_INTERVAL=15
CAPTEURS_ERROR_RATE=0.04
